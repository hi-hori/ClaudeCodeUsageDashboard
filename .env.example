# Dashboard URL (default: http://localhost:5173)
CLAUDE_CODE_USAGE_DASHBOARD_URL=

# Cloudflare Access Service Token (production only)
# Zero Trust dashboard > Access > Service Auth > Service Tokens で発行
CLAUDE_CODE_USAGE_DASHBOARD_CF_ACCESS_CLIENT_ID=
CLAUDE_CODE_USAGE_DASHBOARD_CF_ACCESS_CLIENT_SECRET=

# --- プラグインインストール時の .env 配置場所 ---
# ~/.claude/plugins/claude-code-usage-dashboard/.env
#
# プロジェクトごとに異なる URL を使う場合は、
# プロジェクトルートの .env に設定すると優先されます。
